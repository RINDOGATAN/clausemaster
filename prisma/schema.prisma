generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["clausemaster"]
}

// ============================================================
// AUTHENTICATION & USERS
// ============================================================

enum UserRole {
  INTERNAL
  PUBLISHER
  CLIENT

  @@schema("clausemaster")
}

enum AIProvider {
  COMMUNITY
  ANTHROPIC
  OPENAI
  GROQ
  MISTRAL
  TOGETHER

  @@schema("clausemaster")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CLIENT)
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  aiProvider      AIProvider @default(COMMUNITY)
  aiModel         String?

  encryptedApiKey String? @db.Text
  apiKeyIv        String?

  accounts         Account[]
  sessions         Session[]
  documents        Document[]
  publisherProfile PublisherProfile?
  clientRequests   ReviewRequest[]  @relation("clientRequests")
  publisherReviews ReviewRequest[]  @relation("publisherReviews")

  @@map("users")
  @@schema("clausemaster")
}

model PublisherInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String?
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@map("publisher_invites")
  @@schema("clausemaster")
}

model PublisherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firmName    String?
  bio         String?  @db.Text
  specialties String[]
  website     String?

  // Stripe Connect (revenue share for published skills)
  stripeConnectAccountId String?
  stripeConnectComplete  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("publisher_profiles")
  @@schema("clausemaster")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("clausemaster")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("clausemaster")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("clausemaster")
}

// ============================================================
// DOCUMENTS & ANALYSIS
// ============================================================

enum FileType {
  PDF
  DOCX
  TXT

  @@schema("clausemaster")
}

enum DocumentStatus {
  UPLOADED
  EXTRACTING
  ANALYZING
  COMPLETED
  FAILED

  @@schema("clausemaster")
}

enum Jurisdiction {
  CALIFORNIA
  ENGLAND_WALES
  SPAIN
  UNKNOWN

  @@schema("clausemaster")
}

enum IssueType {
  MISSING_CLAUSE
  UNUSUAL_TERM
  JURISDICTION_CONCERN
  AMBIGUITY
  IMBALANCE
  COMPLIANCE_RISK

  @@schema("clausemaster")
}

enum IssueSeverity {
  INFO
  WARNING
  CRITICAL

  @@schema("clausemaster")
}

enum BiasAssessment {
  NEUTRAL
  FAVORS_PARTY_A
  FAVORS_PARTY_B

  @@schema("clausemaster")
}

model Document {
  id           String         @id @default(cuid())
  userId       String
  fileName     String
  fileType     FileType
  fileSize     Int
  fileData     Bytes?
  status       DocumentStatus @default(UPLOADED)
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis       Analysis?
  reviewRequests ReviewRequest[]

  @@index([userId])
  @@map("documents")
  @@schema("clausemaster")
}

model Analysis {
  id                   String       @id @default(cuid())
  documentId           String       @unique
  contractType         String?
  contractTypeLabel    String?
  jurisdiction         Jurisdiction @default(UNKNOWN)
  jurisdictionNotes    String?
  summary              String?      @db.Text
  partyNames           String[]
  effectiveDate        String?
  documentCategory     String?
  partyMode            String?
  suggestedDestination String?
  aiProvider           String?
  aiModel              String?
  processingTimeMs     Int?
  rawExtractedText     String?      @db.Text
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  clauses    AnalyzedClause[]
  issues     Issue[]
  skillDraft SkillDraft?

  @@map("analyses")
  @@schema("clausemaster")
}

model AnalyzedClause {
  id                String          @id @default(cuid())
  analysisId        String
  order             Int
  title             String
  category          String?
  originalText      String          @db.Text
  summary           String?         @db.Text
  legalSignificance String?         @db.Text
  skillClauseMatch  String?
  biasAssessment    BiasAssessment  @default(NEUTRAL)
  createdAt         DateTime        @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  issues   Issue[]

  @@index([analysisId])
  @@map("analyzed_clauses")
  @@schema("clausemaster")
}

model Issue {
  id               String        @id @default(cuid())
  analysisId       String
  clauseId         String?
  type             IssueType
  severity         IssueSeverity
  title            String
  description      String        @db.Text
  recommendation   String?       @db.Text
  jurisdictionNote String?
  createdAt        DateTime      @default(now())

  analysis Analysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  clause   AnalyzedClause? @relation(fields: [clauseId], references: [id], onDelete: SetNull)

  @@index([analysisId])
  @@index([clauseId])
  @@map("issues")
  @@schema("clausemaster")
}

// ============================================================
// SKILL DRAFTS (Deal Room Skill Generation)
// ============================================================

enum SkillDraftStatus {
  GENERATING
  REVIEW
  SUBMITTED
  APPROVED
  REJECTED
  EXPORTED
  FAILED

  @@schema("clausemaster")
}

enum SkillType {
  CONTRACT
  ASSESSMENT

  @@schema("clausemaster")
}

enum PartyMode {
  TWO_PARTY
  SOLO

  @@schema("clausemaster")
}

enum SkillDestination {
  DEAL_ROOM
  DPO_CENTRAL
  AI_SENTINEL

  @@schema("clausemaster")
}

model SkillDraft {
  id            String           @id @default(cuid())
  analysisId    String           @unique
  status        SkillDraftStatus @default(GENERATING)
  errorMessage  String?

  // Skill type & routing
  skillType     SkillType        @default(CONTRACT)
  partyMode     PartyMode?
  destination   SkillDestination?

  // Generated skill data (stored as JSON)
  skillId         String?
  contractType    String?
  displayName     String?
  clausesJson     Json?
  boilerplateJson Json?
  metadataJson    Json?
  manifestJson    Json?
  assessmentJson  Json?
  guidanceJson    Json?

  // AI tracking
  aiProvider       String?
  aiModel          String?
  processingTimeMs Int?

  // Submission tracking (publisher flow)
  submittedAt    DateTime?
  reviewedByUser String?
  reviewNotes    String?  @db.Text

  // Export tracking
  exportedAt DateTime?
  exportPath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("skill_drafts")
  @@schema("clausemaster")
}

// ============================================================
// REVIEW REQUESTS (Client → Publisher)
// ============================================================

enum ReviewStatus {
  PENDING
  CLAIMED
  COMPLETED
  CANCELLED

  @@schema("clausemaster")
}

model ReviewRequest {
  id           String       @id @default(cuid())
  documentId   String
  clientId     String
  publisherId  String?
  status       ReviewStatus @default(PENDING)
  clientNotes  String?      @db.Text
  reviewNotes  String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  client    User     @relation("clientRequests", fields: [clientId], references: [id])
  publisher User?    @relation("publisherReviews", fields: [publisherId], references: [id])

  @@map("review_requests")
  @@schema("clausemaster")
}
