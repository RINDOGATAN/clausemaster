# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=clausemaster

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3002

# Platform AI key (used by privileged-domain users)
ANTHROPIC_API_KEY=

# Community tier — platform-provided open model (free for all users)
# Users who don't bring their own key get this model automatically.
# PLATFORM_AI_PROVIDER=groq
# PLATFORM_AI_MODEL=llama-3.3-70b-versatile
# PLATFORM_AI_API_KEY=gsk_...
# PLATFORM_AI_BASE_URL=https://api.groq.com/openai/v1

# Google OAuth (optional — sign-in falls back to magic link only)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email via Resend (optional — magic links log to console if unset)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# Invite code gate (optional — unset = open access)
# INVITE_CODE=

# LegalSkills reference repo (optional — defaults to ../legalskills)
# LEGALSKILLS_DIR=../legalskills

# Encryption secret for user API keys (required for per-user key storage)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=

# Stripe (optional — required for publisher revenue share via Connect)
# STRIPE_SECRET_KEY=sk_test_...

# Dealroom Expert Directory (optional — enables publisher onboarding via expert verification)
# DEALROOM_API_URL=https://dealroom.todo.law/api/v1/experts
# DEALROOM_API_KEY=drk_...

# E2E testing (optional — enables e2e-credentials auth provider for Playwright tests)
# E2E_CREDENTIALS_SECRET=e2e-test-secret
