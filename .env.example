# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=clausemaster

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3002

# AI Provider: anthropic | ollama | openai-compatible
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# Ollama (only if AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:32b

# OpenAI-compatible (only if AI_PROVIDER=openai-compatible)
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8080/v1
# OPENAI_COMPATIBLE_API_KEY=

# Google OAuth (optional — sign-in falls back to magic link only)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email via Resend (optional — magic links log to console if unset)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# Invite code gate (optional — unset = open access)
# INVITE_CODE=

# LegalSkills reference repo (optional — defaults to ../legalskills)
# LEGALSKILLS_DIR=../legalskills

# Encryption secret for user API keys (required for per-user key storage)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=
